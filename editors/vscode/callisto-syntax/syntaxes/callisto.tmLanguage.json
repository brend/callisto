{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Callisto",
  "scopeName": "source.callisto",
  "fileTypes": [
    "cal",
    "luna"
  ],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#declarations"
    },
    {
      "include": "#moduleImports"
    },
    {
      "include": "#bindings"
    },
    {
      "include": "#callsAndAccess"
    },
    {
      "include": "#parameters"
    },
    {
      "include": "#keywords"
    },
    {
      "include": "#constants"
    },
    {
      "include": "#typesAndConstructors"
    },
    {
      "include": "#numbers"
    },
    {
      "include": "#operators"
    }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.callisto",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.callisto",
          "begin": "\"",
          "beginCaptures": {
            "0": {
              "name": "punctuation.definition.string.begin.callisto"
            }
          },
          "end": "\"",
          "endCaptures": {
            "0": {
              "name": "punctuation.definition.string.end.callisto"
            }
          },
          "patterns": [
            {
              "name": "constant.character.escape.callisto",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "declarations": {
      "patterns": [
        {
          "name": "meta.declaration.function.callisto",
          "match": "\\b(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.function.callisto"
            },
            "2": {
              "name": "entity.name.function.callisto"
            }
          }
        },
        {
          "name": "meta.declaration.type.callisto",
          "match": "\\b(type)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "storage.type.callisto"
            },
            "2": {
              "name": "entity.name.type.callisto"
            }
          }
        },
        {
          "name": "meta.declaration.impl.callisto",
          "match": "\\b(impl)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.declaration.impl.callisto"
            },
            "2": {
              "name": "entity.name.type.callisto"
            }
          }
        }
      ]
    },
    "moduleImports": {
      "patterns": [
        {
          "name": "meta.path.module.callisto",
          "match": "\\b(module|import)\\s+([a-zA-Z_][a-zA-Z0-9_]*(?:\\.[a-zA-Z_][a-zA-Z0-9_]*)*)",
          "captures": {
            "1": {
              "name": "keyword.other.module.callisto"
            },
            "2": {
              "name": "entity.name.namespace.callisto"
            }
          }
        }
      ]
    },
    "bindings": {
      "patterns": [
        {
          "name": "meta.binding.local.callisto",
          "match": "\\b(let|var)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\b",
          "captures": {
            "1": {
              "name": "keyword.other.callisto"
            },
            "2": {
              "name": "variable.other.local.callisto"
            }
          }
        },
        {
          "name": "meta.assignment.local.callisto",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(=)",
          "captures": {
            "1": {
              "name": "variable.other.local.callisto"
            },
            "2": {
              "name": "keyword.operator.assignment.callisto"
            }
          }
        }
      ]
    },
    "callsAndAccess": {
      "patterns": [
        {
          "name": "meta.method.call.callisto",
          "match": "\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.method.callisto"
            }
          }
        },
        {
          "name": "meta.field.access.callisto",
          "match": "\\.\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\b(?!\\s*\\()",
          "captures": {
            "1": {
              "name": "variable.other.property.callisto"
            }
          }
        },
        {
          "name": "meta.function.call.callisto",
          "match": "\\b(?!fn\\b|if\\b|then\\b|elseif\\b|else\\b|match\\b|case\\b|while\\b|do\\b|for\\b|in\\b|return\\b|end\\b|let\\b|var\\b|module\\b|import\\b|type\\b|impl\\b|extern\\b|pub\\b|and\\b|or\\b|not\\b|with\\b)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
          "captures": {
            "1": {
              "name": "entity.name.function.call.callisto"
            }
          }
        }
      ]
    },
    "parameters": {
      "patterns": [
        {
          "name": "meta.parameter.declaration.callisto",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
          "captures": {
            "1": {
              "name": "variable.parameter.callisto"
            },
            "2": {
              "name": "punctuation.separator.type.annotation.callisto"
            }
          }
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "storage.modifier.callisto",
          "match": "\\b(pub|extern)\\b"
        },
        {
          "name": "keyword.control.callisto",
          "match": "\\b(if|then|elseif|else|match|case|while|do|for|in|return|end|with)\\b"
        },
        {
          "name": "keyword.other.callisto",
          "match": "\\b(let|var)\\b"
        },
        {
          "name": "keyword.operator.logical.callisto",
          "match": "\\b(and|or|not)\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.boolean.callisto",
          "match": "\\b(true|false)\\b"
        },
        {
          "name": "variable.language.wildcard.callisto",
          "match": "\\b_\\b"
        }
      ]
    },
    "typesAndConstructors": {
      "patterns": [
        {
          "name": "support.type.builtin.callisto",
          "match": "\\b(Int|Float|Bool|String|Unit|Nil|nil)\\b"
        },
        {
          "name": "entity.name.type.callisto",
          "match": "\\b[A-Z][a-zA-Z0-9_]*\\b"
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.float.callisto",
          "match": "\\b\\d+\\.\\d+\\b"
        },
        {
          "name": "constant.numeric.integer.callisto",
          "match": "\\b\\d+\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.callisto",
          "match": "=>|->|\\.\\.|==|!=|<=|>=|=|<|>|\\+|-|\\*|/|%|\\||\\."
        },
        {
          "name": "punctuation.separator.callisto",
          "match": ",|:"
        },
        {
          "name": "punctuation.section.brackets.callisto",
          "match": "[\\[\\]\\(\\)\\{\\}]"
        }
      ]
    }
  }
}
