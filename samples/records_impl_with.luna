module records_impl_with

type Vec2 { x: Int, y: Int }

impl Vec2 do
  fn length_sq(self: Vec2) -> Int do
    self.x * self.x + self.y * self.y
  end

  fn moved(self: Vec2, dx: Int, dy: Int) -> Vec2 do
    self with { x = self.x + dx, y = self.y + dy }
  end
end

pub fn main() -> Int do
  let start = Vec2 { x = 3, y = 4 }
  let shifted = start.moved(1, 2)
  shifted.length_sq()
end
