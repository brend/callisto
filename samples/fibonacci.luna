module fibonacci

// Compute the nth Fibonacci number recursively.
pub fn fib(n: Int) -> Int do
  if n <= 1 then
    n
  else
    fib(n - 1) + fib(n - 2)
  end
end

// Compute the nth Fibonacci number iteratively using mutable bindings.
pub fn fib_iter(n: Int) -> Int do
  if n <= 1 then
    n
  else
    var a = 0
    var b = 1
    var i = 2
    while i <= n do
      let tmp = a + b
      a = b
      b = tmp
      i = i + 1
    end
    b
  end
end

pub fn main() -> Int do
  fib_iter(10)
end
